# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# agent tooling config (local, not project source)
.agents/

# stray debug/scratch scripts from proving debugging sessions (unused, unreferenced)
debug_hashes.ts
disburse_test.ts
dummy.js
empty.js
slice_result.txt
dev.log

# duplicate of tecta-wasm/circuits — the real one this app builds proofs
# against lives in the sibling tecta-wasm repo; this copy is unused/stray
/circuits

# regenerated by copy-wasm.mjs (postinstall) from node_modules — binary build output
/public/wasm

# design-sync: staged converter scripts + build output + machine state
/.ds-sync
/ds-bundle
/.design-sync/.cache
/.design-sync/learnings
/.design-sync/node_modules

# Copy this file to .env (or .env.local) and fill in real values before running the app.
# Don't forget this step — without it the dashboard can't find your deployed contracts.

# Contract IDs from your tecta-zk deployment (see https://github.com/azzaky9/tecta-zk).
# NEXT_PUBLIC_* variants are exposed to the browser — contract IDs aren't secrets, this is fine.
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_PAYROLL_ID=
NEXT_PUBLIC_STELLAR_VERIFIER_ID=

# Server-side copies, used by API routes (app/api/*)
STELLAR_NETWORK=testnet
STELLAR_PAYROLL_ID=
STELLAR_VERIFIER_ID=

# Server-only. Pays fees for employee claims from fresh (0 XLM) wallets.
# Generate a DEDICATED keypair for this — never reuse your HR/admin key.
# Never prefix this with NEXT_PUBLIC_ — it must never reach the browser bundle.
# Put this in .env.local (gitignored), not .env.
PAYROLL_SPONSOR_SECRET=
